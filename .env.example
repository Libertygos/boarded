# À l'abordage server environment
PORT=2567

# Shared secret with the gosgames platform for verifying handoff tokens (HS256).
HANDOFF_JWT_SECRET=

# Secret for signing the game's own session S-JWT (independent of the handoff secret).
SESSION_JWT_SECRET=

# Local development only: set to 1 to enable POST /auth/dev (guest login without the
# platform). NEVER set in production.
DEV_AUTH=

# gosgames platform internal service channel (best-effort; unset → features no-op):
#  - match reporting (POST /api/internal/matches)
#  - active-game presence lease (POST /api/internal/presence/{start,heartbeat,end})
#  - platform → game remote-end (Bearer-authed POST /internal/sessions/end on THIS server)
# GOSGAMES_INTERNAL_URL is the platform base URL; INTERNAL_SERVICE_TOKEN is the shared
# service token (sent as X-Internal-Token outbound, required as Bearer on remote-end).
GOSGAMES_INTERNAL_URL=
INTERNAL_SERVICE_TOKEN=
