# À l'abordage server environment
PORT=2567

# Shared secret with the gosgames platform for verifying handoff tokens (HS256).
HANDOFF_JWT_SECRET=

# Secret for signing the game's own session S-JWT (independent of the handoff secret).
SESSION_JWT_SECRET=

# Local development only: set to 1 to enable POST /auth/dev (guest login without the
# platform). NEVER set in production.
DEV_AUTH=
