{
  "name": "boarded",
  "version": "1.0.0",
  "private": true,
  "description": "À l'abordage — card drafting / take-that treasure race, gosgames tenant.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter ./packages/engine build && pnpm -r build",
    "build:engine": "pnpm --filter @boarded/engine build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev:server": "pnpm --filter @boarded/server dev",
    "dev:client": "pnpm --filter @boarded/client dev"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@11.8.0"
}
